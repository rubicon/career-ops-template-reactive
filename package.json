{
  "name": "career-ops-template-reactive",
  "version": "0.1.1",
  "description": "The career-ops reactive template pack: fifteen ATS-strict CV and cover-letter theme pairs, ported from the Reactive Resume designs.",
  "license": "MIT",
  "author": "Dax Davis <dax@rubicontv.com>",
  "homepage": "https://github.com/rubicon/career-ops-template-reactive#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubicon/career-ops-template-reactive.git"
  },
  "bugs": {
    "url": "https://github.com/rubicon/career-ops-template-reactive/issues"
  },
  "keywords": [
    "career-ops",
    "career-ops-templates",
    "cv",
    "resume",
    "cover-letter",
    "ats",
    "template-pack"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "smoke": "node test/smoke.mjs",
    "validate": "node validate-template-pack.mjs --pack pack.json --root .",
    "previews:setup": "npm install --no-save playwright && npx playwright install chromium",
    "previews": "node scripts/generate-previews.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "prettier": "^3.4.2"
  }
}
